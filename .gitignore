cat > .gitignore << 'EOF'
# Python
__pycache__/
*.pyc
.venv/
.env

# Data
data/
outputs/
models/
*.tif
*.tiff
*.png
*.jpg
*.jpeg
*.pth
*.pt
*.ckpt

# Mac
.DS_Store

# Jupyter
.ipynb_checkpoints/

# External reference repositories
external_repos/

# 대용량 모델 가중치 파일은 GitHub 추적에서 제외
weights/*.pth
experiments/